# ============================================================
# Nunge Returns JARVIS System — Environment Variables
# Copy this to .env.local and fill in your values
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI Models ---
GEMINI_API_KEY=your-gemini-api-key
OPENAI_API_KEY=your-openai-api-key

# --- WhatsApp (Evolution API) ---
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=your-evolution-api-key
EVOLUTION_INSTANCE_NAME=nunge-returns

# --- Security ---
ENCRYPTION_KEY=generate-a-strong-random-string-min-32-chars
JWT_SECRET=generate-another-strong-random-string
HMAC_SECRET=generate-yet-another-strong-random-string

# --- Application ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# --- M-Pesa (Optional) ---
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=

# --- Redis (Optional — used for rate limiting if available) ---
REDIS_URL=redis://localhost:6379
